#!/bin/bash
# ==============================================================================
# KVM-Blacksmith: Central Distributed Orchestrator for the KVM-Forge Ecosystem
# ==============================================================================
# Systems Engineering: Script Robustness and Error Handling
# - 'set -e' (errexit): Halts execution if a command exits with a non-zero status.
# - 'set -u' (nounset): Treats references to unset variables as errors.
# - 'set -o pipefail': Ensures pipeline status reflects the rightmost non-zero exit code.
# ==============================================================================
set -euo pipefail

# Resolve roots using pure Bash parameter expansion to ensure compatibility in restricted PATH envs
if [[ "${BASH_SOURCE[0]}" == */* ]]; then
    BLACKSMITH_BIN="${BASH_SOURCE[0]%/*}"
else
    BLACKSMITH_BIN="."
fi
if [[ "$BLACKSMITH_BIN" == */* ]]; then
    BLACKSMITH_ROOT="${BLACKSMITH_BIN%/*}"
else
    BLACKSMITH_ROOT="."
fi
[ -z "$BLACKSMITH_ROOT" ] && BLACKSMITH_ROOT="."
BLACKSMITH_LIB="$BLACKSMITH_ROOT/lib"

CONFIG_FILE="${CONFIG_FILE:-$BLACKSMITH_ROOT/config/anvils.yaml}"
SSH_OPTS="-o ConnectTimeout=3 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

# Source modular libraries safely
for lib in utils manifest cmd_status cmd_list cmd_provision cmd_tui cmd_destroy; do
    lib_path="$BLACKSMITH_LIB/${lib}.sh"
    if [ -f "$lib_path" ]; then
        source "$lib_path"
    else
        echo -e "\033[1;31m[ERROR]\033[0m Required library file not found: $lib_path" >&2
        exit 1
    fi
done

# ==============================================================================
# Usage & Main Entrypoint
# ==============================================================================
usage() {
    echo "Usage: kvm-blacksmith <command> [options]"
    echo "Commands:"
    echo "  status               Inspect and visualize cluster hypervisor health & capacity"
    echo "  list, vms            Display a unified status overview of all guest VMs in cluster"
    echo "  provision [OPTIONS]  Schedule and deploy a VM based on capacity constraints"
    echo "  tui                  Launch dynamic gum-powered interactive provisioning wizard"
    echo "  destroy <vm-name>    Scan cluster, stop guest, and wipe domain and VM storage"
    echo ""
    echo "Provisioning Options:"
    echo "  -t, --tui            Launch dynamic gum-powered interactive provisioning wizard"
    echo "  -d, --distro <dist>  Operating system distribution (default: ubuntu)"
    echo "  -v, --version <ver>  Distribution version override (e.g. 24.04)"
    echo "  -p, --profile <prof> Custom profile (default: base)"
    echo "  -c, --cpus <count>   Virtual CPUs requested (default: 4)"
    echo "  -m, --memory <ram>   Memory size in MB (default: 8192)"
    echo "  -s, --disk-size <gb> Target disk volume in GB (default: 30)"
    echo "  --anvil <name>       Enforce target hypervisor selection (bypasses capacity scheduler)"
    exit 0
}

main() {
    if [ $# -lt 1 ]; then
        usage
    fi

    local command="$1"
    shift

    case "$command" in
        status)
            cmd_status
            ;;
        list|vms)
            cmd_list
            ;;
        provision)
            cmd_provision "$@"
            ;;
        tui)
            cmd_tui "$@"
            ;;
        destroy)
            cmd_destroy "$@"
            ;;
        -h|--help|help)
            usage
            ;;
        *)
            log_err "Unknown command: $command"
            usage
            ;;
    esac
}

# Source forge config environment if not in bats testing environment
if [ -z "${BATS_RUNNING:-}" ] && [ -f "$BLACKSMITH_ROOT/config/forge.env" ]; then
    FORGE_ENV_FILE="$BLACKSMITH_ROOT/config/forge.env"
    if validate_forge_env_file "$FORGE_ENV_FILE"; then
        # Sourcing validated configuration safely
        set +u
        source "$FORGE_ENV_FILE"
        set -u
    else
        log_err "Security alert: Malformed options in environment config file. Refusing to load."
        exit 1
    fi
fi

# Execute entrypoint if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
